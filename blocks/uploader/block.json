{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 2,
  "name": "wedding-photo-uploader/photo-form",
  "version": "0.1.0",
  "title": "Wedding Media Uploader",
  "category": "widgets",
  "icon": "format-gallery",
  "description": "Upload form for wedding photos and videos requiring approval",
  "supports": {
    "html": false,
    "color": {
      "background": true,
      "text": true,
      "link": true
    },
    "typography": {
      "fontSize": true,
      "lineHeight": true
    },
    "spacing": {
      "padding": true
    }
  },
  "attributes": {
    "title": {
      "type": "string",
      "default": "Share Your Wedding Media"
    },
    "description": {
      "type": "string",
      "default": "Please upload your wedding photos and videos here. They will be reviewed before being added to the gallery."
    },
    "submitButtonText": {
      "type": "string",
      "default": "Upload Media"
    },
    "backgroundColor": {
      "type": "string"
    },
    "textColor": {
      "type": "string"
    },
    "fontSize": {
      "type": "string"
    },
    "padding": {
      "type": "object",
      "default": {
        "top": "20px",
        "right": "20px",
        "bottom": "20px",
        "left": "20px"
      }
    },
    "borderRadius": {
      "type": "string",
      "default": "5px"
    }
  },
  "textdomain": "wedding-photo-uploader",
  "editorScript": "file:./build/index.js",
  "editorStyle": "file:./build/style-index.css",
  "style": "file:./build/style-index.css"
} 
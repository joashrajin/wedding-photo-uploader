{
  "name": "wedding-photo-uploader",
  "version": "1.1.8",
  "description": "WordPress plugin for wedding photo and video uploads with gallery display",
  "scripts": {
    "build": "npm run build:uploader && npm run build:gallery",
    "build:uploader": "wp-scripts build blocks/uploader/src/index.js --output-path=blocks/uploader/build",
    "build:gallery": "wp-scripts build blocks/gallery/src/index.js --output-path=blocks/gallery/build",
    "start:uploader": "wp-scripts start blocks/uploader/src/index.js --output-path=blocks/uploader/build",
    "start:gallery": "wp-scripts start blocks/gallery/src/index.js --output-path=blocks/gallery/build",
    "check-engines": "wp-scripts check-engines",
    "check-licenses": "wp-scripts check-licenses",
    "format": "wp-scripts format",
    "lint:css": "wp-scripts lint-style",
    "lint:js": "wp-scripts lint-js",
    "lint:md:docs": "wp-scripts lint-md-docs",
    "lint:pkg-json": "wp-scripts lint-pkg-json",
    "packages-update": "wp-scripts packages-update"
  },
  "dependencies": {
    "@wordpress/block-editor": "^12.15.0",
    "@wordpress/blocks": "^12.24.0",
    "@wordpress/components": "^25.13.0",
    "@wordpress/i18n": "^4.47.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@wordpress/scripts": "^30.13.0",
    "@playwright/test": "^1.42.1",
    "eslint": "^8.57.0",
    "typescript": "^5.4.2"
  },
  "overrides": {
    "glob": "^9.3.5",
    "rimraf": "^5.0.5",
    "core-js": "^3.36.0",
    "@babel/runtime": "^7.26.10",
    "ws": "^8.16.0",
    "cross-spawn": "^7.0.5",
    "@humanwhocodes/config-array": "@eslint/config-array@^1.0.0",
    "@humanwhocodes/object-schema": "@eslint/object-schema@^1.0.0",
    "inflight": "npm:lru-cache@^10.2.0",
    "svgo": "^3.2.0",
    "postcss-markdown": "^0.37.0",
    "postcss-css-in-js": "^0.37.0",
    "sane": "^5.1.3",
    "w3c-hr-time": "^2.0.0",
    "domexception": "^4.0.0",
    "abab": "^2.0.6",
    "urix": "^0.1.0",
    "source-map-url": "^0.4.1",
    "resolve-url": "^0.2.1",
    "source-map-resolve": "^0.5.3",
    "q": "^1.5.3",
    "stable": "^0.2.0"
  },
  "engines": {
    "node": ">=18.12.0",
    "npm": ">=8.19.2"
  },
  "license": "GPL-2.0-or-later"
} 